---
# Configuración de ansible-lint para este proyecto
# El perfil "production" es el más estricto; es el que promete el badge del README
profile: production

skip_list:
  # Los playbooks viven en playbooks/ y las plantillas compartidas en
  # templates/, por lo que el src usa "{{ playbook_dir }}/../templates/...".
  # La regla lo marca como ruta relativa, pero aquí es intencionado.
  - no-relative-paths

exclude_paths:
  - informes/
  - entorno-prueba/
